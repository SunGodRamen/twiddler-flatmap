# semantic action = android binding

NAV_UP=DPAD_UP
NAV_RIGHT=DPAD_RIGHT
NAV_LEFT=DPAD_LEFT
NAV_DOWN=DPAD_DOWN
NAV_PAGEUP=KEYCODE_PAGE_UP
NAV_PAGEDOWN=KEYCODE_PAGE_DOWN
NAV_HOME=KEYCODE_MOVE_HOME
NAV_END=KEYCODE_MOVE_END

UI_SPACE=SPACE
UI_TAB=TAB
UI_BACKTAB=SHIFT+TAB
UI_ENTER=ENTER
UI_ESCAPE=ESCAPE

EDIT_COPY=CTRL+C
EDIT_PASTE=CTRL+V

MEDIA_VOLUME_DOWN=SHIFT+VOLUME_DOWN
SYS_SCROLLLOCK=SCROLL_LOCK

RAW_128=UNRESOLVED
